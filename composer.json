{
    "name": "gemorroj/htmlvalidator",
    "type": "library",
    "description": "W3C HTML Validator service.",
    "license": "LGPL-3.0-or-later",
    "require": {
        "php": ">=8.1",
        "symfony/http-client": "^7.4||^8.0"
    },
    "authors": [
        {
            "name": "Gemorroj"
        }
    ],
    "require-dev": {
        "phpunit/phpunit": "^11.5||^12.5",
        "friendsofphp/php-cs-fixer": "^3.93"
    },
    "autoload": {
        "psr-4": {
            "HTMLValidator\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HTMLValidator\\Tests\\": "tests/"
        }
    }
}
